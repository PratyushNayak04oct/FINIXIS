<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml" fx:controller="com.finixis.controller.AccountController"
            fitToWidth="true" fitToHeight="true" styleClass="scroll-pane" hbarPolicy="NEVER">
    <VBox styleClass="page" prefWidth="720" spacing="20">
        <HBox alignment="CENTER_LEFT" spacing="14">
            <FontIcon iconLiteral="fas-user-circle" styleClass="page-title"/>
            <VBox>
                <Label text="Account &amp; Profile" styleClass="page-title"/>
                <Label text="Your profile and appearance settings" styleClass="page-subtitle"/>
            </VBox>
        </HBox>

        <VBox styleClass="card,card-pad" spacing="14">
            <HBox spacing="16" alignment="CENTER_LEFT">
                <Label fx:id="avatar" text="AH" styleClass="avatar"/>
                <VBox spacing="2">
                    <Label fx:id="nameLabel" text="—" style="-fx-font-size:18px; -fx-font-weight:700;"/>
                    <Label fx:id="roleLabel" text="—" styleClass="chip,chip-primary"/>
                </VBox>
            </HBox>

            <HBox styleClass="sep"/>

            <VBox spacing="6">
                <Label text="Email" styleClass="stat-label"/>
                <TextField fx:id="emailField" styleClass="field" prefWidth="500"/>
            </VBox>
            <VBox spacing="6">
                <Label text="Phone" styleClass="stat-label"/>
                <TextField fx:id="phoneField" styleClass="field" prefWidth="500"/>
            </VBox>
            <HBox spacing="10">
                <Button text="Save" styleClass="btn" onAction="#onSave"/>
                <Button text="Cancel" styleClass="btn,btn-secondary" onAction="#onCancel"/>
            </HBox>
        </VBox>

        <VBox styleClass="card,card-pad" spacing="12">
            <Label text="APPEARANCE" styleClass="card-title"/>
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="Theme:" styleClass="txn-meta"/>
                <Button fx:id="themeBtn" text="Switch to Dark" styleClass="btn,btn-secondary" onAction="#onToggleTheme">
                    <graphic><FontIcon iconLiteral="fas-moon"/></graphic>
                </Button>
                <Label text="Toggle between light and dark mode. Every screen supports both." styleClass="txn-meta"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
