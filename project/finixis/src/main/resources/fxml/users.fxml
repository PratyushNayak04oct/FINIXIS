<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml" fx:controller="com.finixis.controller.UsersController" styleClass="page">
    <HBox alignment="CENTER_LEFT" spacing="14">
        <FontIcon iconLiteral="fas-user-shield" styleClass="page-title"/>
        <VBox>
            <Label text="User Management" styleClass="page-title"/>
            <Label text="Admin-only: manage staff accounts and roles" styleClass="page-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="addUserBtn" text="Add New User" styleClass="btn" onAction="#onAddUser">
            <graphic><FontIcon iconLiteral="fas-user-plus"/></graphic>
        </Button>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="nameCol" text="Name" prefWidth="200"/>
            <TableColumn fx:id="emailCol" text="Email" prefWidth="240"/>
            <TableColumn fx:id="phoneCol" text="Phone" prefWidth="160"/>
            <TableColumn fx:id="roleCol" text="Role" prefWidth="120"/>
            <TableColumn fx:id="statusCol" text="Status" prefWidth="120"/>
            <TableColumn fx:id="actionCol" text="Actions" prefWidth="100" sortable="false"/>
        </columns>
    </TableView>
</VBox>
